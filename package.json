{
  "name": "tourisk-mobile",
  "version": "1.8.6",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-expo.js",
    "ios": "node scripts/start-expo.js --ios",
    "android": "node scripts/start-expo.js --android",
    "web": "expo start --web",
    "doctor": "expo-doctor",
    "start:plain": "expo start --clear --lan",
    "start:tunnel": "expo start --clear --tunnel",
    "start:offline": "EXPO_OFFLINE=1 expo start --clear --lan",
    "check": "expo config --type public && expo export --platform ios --output-dir .expo-check",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.34",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1"
  }
}
